# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Search backend (SearxNG) ---
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_LANGUAGE=fr
SEARXNG_SAFESEARCH=1

# --- HTTP client ---
HTTP_TIMEOUT_SECONDS=10
HTTP_USER_AGENT=web-tools/0.1 (+https://example.local)
HTTP_MAX_REDIRECTS=5

# --- Limits ---
MAX_HTML_BYTES=2000000
MAX_HTML_CHARS=500000
MAX_TEXT_CHARS=50000

# --- Search limits ---
SEARCH_DEFAULT_LIMIT=5
SEARCH_MAX_LIMIT=20
